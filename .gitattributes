# Normalize line endings for all text files to LF in the repo
* text=auto eol=lf

# Explicitly set common file types
*.md   text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.toml text eol=lf

# Binary files — no line ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
